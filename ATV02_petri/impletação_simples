public class PilhaSimples {
    private String[] pilha;
    private int topo;

    public PilhaSimples(int tamanho) {
        this.pilha = new String[tamanho];
        this.topo = -1;
        System.out.println("Pilha Simples criada!");
    }

    public boolean estaVazia() {
        return topo == -1;
    }

    public boolean estaCheia() {
        return topo == pilha.length - 1;
    }

    public void push(String elemento) {
        if (!estaCheia()) {
            topo++;
            pilha[topo] = elemento;
            System.out.println("Elemento " + elemento + " empilhado!");
        } else {
            System.out.println("Pilha cheia!");
        }
    }

    public String pop() {
        if (!estaVazia()) {
            String removido = pilha[topo];
            pilha[topo] = null;
            topo--;
            System.out.println("Elemento " + removido + " removido!");
            return removido;
        } else {
            System.out.println("Pilha vazia!");
            return null;
        }
    }

    public String peek() {
        if (!estaVazia()) {
            return pilha[topo];
        } else {
            System.out.println("Pilha vazia!");
            return null;
        }
    }

    public void exibir() {
        if (!estaVazia()) {
            for (int i = topo; i >= 0; i--) {
                System.out.println("[" + i + "] = " + pilha[i]);
            }
        } else {
            System.out.println("Pilha vazia!");
        }
    }

    // COMPLEMENTARES

    public int contar() {
        return topo + 1;
    }

    public void limpar() {
        while (!estaVazia()) {
            pop();
        }
        System.out.println("Pilha limpa!");
    }

    public boolean contem(String elemento) {
        for (int i = 0; i <= topo; i++) {
            if (pilha[i].equals(elemento)) {
                return true;
            }
        }
        return false;
    }
}